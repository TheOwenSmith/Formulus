{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "start": "pnpm run build && pnpm run preview",
    "build": "node ./esbuild.config.mjs",
    "dev": "concurrently \"node ./esbuild.config.mjs --watch\" \"nodemon --watch ./dist/index.js --exec \\\"node ./dist/index.js\\\"\"",
    "preview": "node ./dist/index.js",
    "build:lambda": "node ./esbuild.lambda.config.mjs",
    "console": "node ./src/scripts/esbuild-console.config.mjs && node ./dist/console.js",
    "prettier:write": "prettier \"**/*.{ts,js}\" --write",
    "prettier:check": "prettier \"**/*.{ts,js}\" --check",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema=../shared/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../shared/prisma/schema.prisma"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sort-keys": "^2.3.5",
    "nodemon": "^3.1.11",
    "prisma": "^7.4.0",
    "typescript-eslint": "^8.46.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/cohere": "^3.0.28",
    "@aws-sdk/client-sqs": "^3.985.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.2",
    "@trpc/server": "^11.8.1",
    "ai": "^6.0.146",
    "better-auth": "^1.4.10",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "nanoid": "^5.1.6",
    "neverthrow": "^8.2.0",
    "pg": "^8.16.3",
    "source-map-support": "^0.5.21",
    "zod": "^4.1.12"
  }
}
