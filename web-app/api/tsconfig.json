{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    "rootDir": "..",
    "outDir": "./dist",
  },
  "include": ["./src/**/*", "../api/src/shared/**/*", "../worker/src/lib/docker.ts", "../worker/src/heap.ts", "../worker/src/utils/date-utils.ts", "../worker/src/utils/types.ts", "../worker/src/utils/cleanup.ts", "../worker/src/utils/number-utils.ts", "../worker/src/utils/group-by.ts", "../worker/src/utils/sharpe-ratio-calculator.ts"],
  "exclude": ["node_modules", "dist", "generated", "*.config.ts", "*.config.mjs"]
}
