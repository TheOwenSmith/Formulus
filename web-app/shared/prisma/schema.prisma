// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  name          String
  email         String @unique
  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]

  algorithms Algorithm[] @relation("UserAlgorithms")

  backtestingResults BacktestingResults[] @relation("UserBacktestingResults")
  backtestingShares BacktestingShare[] @relation("UserBacktestingShare")
  backtestingSubmissions BacktestingSubmission[] @relation("UserBacktestingSubmissions")

  @@index([email])
  @@map("user")
}

model Session {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  identifier String
  value      String
  expiresAt  DateTime

  @@index([identifier])
  @@map("verification")
}

enum Timestamp {
  min1
  min5
  min15
  min30
  min60
}

enum AlgorithmType {
  NORMAL
  SIMPLE
  TOP_K
}

enum SupportedLanguage {
  javascript
  python
  typescript
  cpp
}

model Algorithm {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type AlgorithmType
  aggregate Timestamp
  algorithmMaxHoldingProportion Float?
  contextLength Int
  indicators String[]
  name String @db.VarChar(64)
  tickers String[]
  userAlgorithmImplementationCode String
  k Int?
  language SupportedLanguage

  creator User @relation("UserAlgorithms", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String

  backtestingResults BacktestingResults[] @relation("AlgorithmBacktestingResults")
  versions AlgorithmVersion[] @relation("AlgorithmVersions")

  @@unique([creatorId, name])
  @@index([creatorId])
  @@map("algorithm")
}

model AlgorithmVersion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type AlgorithmType
  aggregate Timestamp
  algorithmMaxHoldingProportion Float?
  contextLength Int
  indicators String[]
  name String @db.VarChar(64)
  tickers String[]
  userAlgorithmImplementationCode String
  k Int?
  language SupportedLanguage

  algorithm Algorithm @relation("AlgorithmVersions", fields: [algorithmId], references: [id], onDelete: Cascade)
  algorithmId String

  submission BacktestingSubmission @relation("AlgorithmVersionBacktestingSubmissions", fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String

  @@map("algorithm_version")
}

model BacktestingResults {
  id String @id @default(cuid())
  publicId String @unique @db.VarChar(12)
  createdAt DateTime @default(now())

  algorithmGraphs AlgorithmGraph[] @relation("BacktestingResultsAlgorithmGraph")
  tickerPlots TickerPlot[] @relation("BacktestingResultsTickerPlot")
  timestampsByAggregate Json @db.Json

  algorithms Algorithm[] @relation("AlgorithmBacktestingResults")

  creator User @relation("UserBacktestingResults", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String

  shares BacktestingShare[] @relation("BacktestingResultsShare")

  submissions BacktestingSubmission[] @relation("BacktestingResultsSubmissions")

  @@index([creatorId])
  @@index([publicId])
  @@map("backtesting_results")
}

model AlgorithmGraph {
  id String @id @default(cuid())

  aggregate Timestamp
  name String @db.VarChar(64)
  plotYs Float[]

  // Description metrics
  algorithmReturn Float
  averageHoldingDuration Float?
  contextLength Int
  expectancyPerTrade Float?
  growthRate Float
  maxHoldingPorportion Float
  positionsClosed Int
  profitLossRatio Json
  sharpeRatio Float?
  tickers String[]
  timespanStart String
  timespanEnd String
  tradesMade Int
  volatility Float?
  winRate Float?

  backtestingResults BacktestingResults @relation("BacktestingResultsAlgorithmGraph", fields: [backtestingResultsId], references: [id], onDelete: Cascade)
  backtestingResultsId String

  @@index([backtestingResultsId])
  @@map("algorithm_graph")
}

model TickerPlot {
  id String @id @default(cuid())

  aggregate Timestamp
  ticker String @db.VarChar(5)
  
  name String @db.VarChar(64)
  plotYs Float[]

  backtestingResults BacktestingResults @relation("BacktestingResultsTickerPlot", fields: [backtestingResultsId], references: [id], onDelete: Cascade)
  backtestingResultsId String

  @@index([backtestingResultsId])
  @@map("ticker_plot")
}

model BacktestingShare {
  createdAt DateTime @default(now())

  user User @relation("UserBacktestingShare", fields: [userId], references: [id], onDelete: Cascade)
  userId String

  backtestingResults BacktestingResults @relation("BacktestingResultsShare", fields: [backtestingResultsId], references: [id], onDelete: Cascade)
  backtestingResultsId String

  @@id([userId, backtestingResultsId])
  @@index([userId])
  @@index([backtestingResultsId])
  @@map("backtesting_share")
}

enum BacktestingSubmissionStatus {
  PENDING
  RUNNING
  FINISHED
  ERROR
}

model BacktestingSubmission {
  id String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publicId String @unique @db.VarChar(12)
  status BacktestingSubmissionStatus
  progressPct Float @default(0.0)
  message     String?
  error       String?
  errorCode   String?
  errorDetail String? @db.Text

  startTimespan String?
  endTimespan String?

  creator User @relation("UserBacktestingSubmissions", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String

  algorithmVersions AlgorithmVersion[] @relation("AlgorithmVersionBacktestingSubmissions")

  result BacktestingResults? @relation("BacktestingResultsSubmissions", fields: [resultId], references: [id], onDelete: Cascade)
  resultId String?

  @@index([creatorId])
  @@index([publicId])
  @@map("backtesting_submission")
}
