{
  "name": "worker",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "start": "pnpm run build && pnpm run preview",
    "build": "node ./esbuild.config.mjs",
    "dev": "concurrently \"node ./esbuild.config.mjs --watch\" \"nodemon --watch ./dist/index.js --exec \\\"node ./dist/index.js\\\"\"",
    "preview": "node ./dist/index.js",
    "console": "node ./src/scripts/esbuild-console.config.mjs && node ./dist/console.js",
    "prettier:write": "prettier \"**/*.{ts,js}\" --write",
    "prettier:check": "prettier \"**/*.{ts,js}\" --check",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema=../shared/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../shared/prisma/schema.prisma"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sort-keys": "^2.3.5",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "typescript-eslint": "^8.59.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-ecr": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-sqs": "^3.1045.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dockerode": "^4.0.12",
    "dotenv": "^17.4.2",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  }
}
